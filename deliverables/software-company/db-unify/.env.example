# ============================================
# DB-Unify 环境变量配置
# 复制此文件为 .env 并修改相应值
# ============================================

# 服务端口
PORT=3001

# ============================================
# 安全配置（生产环境必须设置）
# ============================================

# AES-256-GCM 加密密钥（64 位十六进制字符串）
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 生产环境必须设置，否则服务拒绝启动
ENCRYPTION_KEY=

# JWT 密钥
# 生成方式同上
JWT_SECRET=

# CORS 允许的来源（逗号分隔，生产环境必须设置）
# 示例：CORS_ORIGIN=https://your-domain.com,https://app.your-domain.com
# 留空则仅在开发环境允许 localhost
CORS_ORIGIN=

# ============================================
# 可选配置
# ============================================

# 日志级别：debug | info | warn | error（默认 info）
LOG_LEVEL=info

# 日志输出目录（默认 ./logs）
LOG_DIR=./logs

# 数据存储目录（默认 ./data）
DATA_DIR=./data
