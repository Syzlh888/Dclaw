{
  "name": "db-unify",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -n vite,api -c blue,green \"vite\" \"nodemon server/index.mjs\"",
    "dev:frontend": "vite",
    "dev:backend": "nodemon server/index.mjs",
    "dev:electron": "concurrently -n vite,electron -c blue,cyan \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -b && vite build && electron-builder --win --x64",
    "build:electron:dir": "tsc -b && vite build && electron-builder --win --x64 --dir",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "keygen": "node scripts/keygen.mjs",
    "keygen:generate": "node scripts/keygen.mjs --generate-keypair"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@monaco-editor/react": "^4.6.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "@tanstack/react-virtual": "^3.5.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.400.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.0",
    "nanoid": "^5.0.0",
    "papaparse": "^5.4.0",
    "pg": "^8.13.0",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql-formatter": "^15.8.1",
    "winston": "^3.15.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/papaparse": "^5.3.14",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  }
}
